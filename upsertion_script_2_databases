    {
      "cell_type": "code",
      "source": [
        "def ensure_pinecone_index(name: str, dim: int = 1536):\n",
        "    existing = pc.list_indexes().names()\n",
        "    if name not in existing:\n",
        "        pc.create_index(\n",
        "            name=name,\n",
        "            dimension=dim,\n",
        "            metric=\"cosine\",\n",
        "            spec=ServerlessSpec(cloud=\"aws\", region=\"us-east-1\")\n",
        "        )\n",
        "    return pc.Index(name)"
      ],
      "metadata": {
        "id": "StPu5ObO8gma"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def safe_upsert(pinecone_index, vectors, namespace):\n",
        "    backoff = INITIAL_BACKOFF\n",
        "    for attempt in range(1, MAX_RETRIES + 1):\n",
        "        try:\n",
        "            pinecone_index.upsert(vectors=vectors, namespace=namespace)\n",
        "            return\n",
        "        except ServiceException as e:\n",
        "            print(f\"[Pinecone] attempt {attempt} failed: {e}. retrying in {backoff:.1f}s...\")\n",
        "            time.sleep(backoff)\n",
        "            backoff *= BACKOFF_FACTOR\n",
        "    raise RuntimeError(f\"Pinecone upsert failed after {MAX_RETRIES} attempts\")\n",
        "\n",
        "def normalize_for_id(value: str) -> str:\n",
        "    return re.sub(r\"[^a-zA-Z0-9]+\", \"-\", value.strip().lower()).strip(\"-\")\n",
        "\n",
        "def make_chunk_id(make: str, model: str, pdf_name: str, page_num: int, chunk_index: int, text: str) -> str:\n",
        "    digest = hashlib.sha1(text.encode(\"utf-8\")).hexdigest()[:12]\n",
        "    return (\n",
        "        f\"{normalize_for_id(make)}:\"\n",
        "        f\"{normalize_for_id(model)}:\"\n",
        "        f\"{normalize_for_id(pdf_name)}:\"\n",
        "        f\"p{page_num}:c{chunk_index}:{digest}\"\n",
        "    )\n",
        "\n",
        "def upsert_manual_chunk(\n",
        "    chunks_col,\n",
        "    *,\n",
        "    chunk_id: str,\n",
        "    make: str,\n",
        "    model: str,\n",
        "    namespace: str,\n",
        "    pdf_name: str,\n",
        "    page_num: int,\n",
        "    chunk_index: int,\n",
        "    text: str,\n",
        "    image_ids: list[str],\n",
        "    pinecone_id: str,\n",
        "    embedding_model: str,\n",
        "    ingestion_run_id: str,\n",
        "):\n",
        "    now = datetime.now(timezone.utc)\n",
        "    chunks_col.update_one(\n",
        "        {\"chunk_id\": chunk_id},\n",
        "        {\n",
        "            \"$set\": {\n",
        "                \"chunk_id\": chunk_id,\n",
        "                \"make\": make,\n",
        "                \"model\": model,\n",
        "                \"namespace\": namespace,\n",
        "                \"pdf\": pdf_name,\n",
        "                \"page\": page_num,\n",
        "                \"chunk_index\": chunk_index,\n",
        "                \"text\": text,\n",
        "                \"image_ids\": image_ids,\n",
        "                \"pinecone_id\": pinecone_id,\n",
        "                \"embedding_model\": embedding_model,\n",
        "                \"schema_version\": CHUNK_SCHEMA_VERSION,\n",
        "                \"ingestion_run_id\": ingestion_run_id,\n",
        "                \"is_active\": True,\n",
        "                \"updated_at\": now,\n",
        "            },\n",
        "            \"$setOnInsert\": {\"created_at\": now},\n",
        "        },\n",
        "        upsert=True,\n",
        "    )"
      ],
      "metadata": {
        "id": "TZklbskp8h6Y"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def process_pdf(pdf_path: str, image_folder: str, mongo_coll, pinecone_index, namespace: str, make: str, model: str, chunks_col):\n",
        "    with pdfplumber.open(pdf_path) as pdf, fitz.open(pdf_path) as fitz_doc:\n",
        "        pdf_name = os.path.basename(pdf_path)\n",
        "        ingestion_run_id = str(uuid4())\n",
        "        batch_texts = []\n",
        "        batch_meta = []\n",
        "\n",
        "        def flush_batch():\n",
        "            if not batch_texts:\n",
        "                return\n",
        "            backoff = INITIAL_BACKOFF\n",
        "            for attempt in range(1, MAX_RETRIES + 1):\n",
        "                try:\n",
        "                    resp = openai.embeddings.create(input=batch_texts, model=EMBED_MODEL)\n",
        "                    vectors = [\n",
        "                        (meta[\"chunk_id\"], emb, meta)\n",
        "                        for emb, meta in zip(\n",
        "                            [d.embedding for d in resp.data],\n",
        "                            batch_meta\n",
        "                        )\n",
        "                    ]\n",
        "                    safe_upsert(pinecone_index, vectors, namespace)\n",
        "                    for meta in batch_meta:\n",
        "                        upsert_manual_chunk(\n",
        "                            chunks_col,\n",
        "                            chunk_id=meta[\"chunk_id\"],\n",
        "                            make=make,\n",
        "                            model=model,\n",
        "                            namespace=namespace,\n",
        "                            pdf_name=meta[\"pdf\"],\n",
        "                            page_num=meta[\"page\"],\n",
        "                            chunk_index=meta[\"chunk_index\"],\n",
        "                            text=meta[\"text\"],\n",
        "                            image_ids=meta[\"image_ids\"],\n",
        "                            pinecone_id=meta[\"chunk_id\"],\n",
        "                            embedding_model=EMBED_MODEL,\n",
        "                            ingestion_run_id=ingestion_run_id,\n",
        "                        )\n",
        "                    batch_texts.clear()\n",
        "                    batch_meta.clear()\n",
        "                    break\n",
        "                except Exception as e:\n",
        "                    if attempt == MAX_RETRIES:\n",
        "                        print(f\"Failed batch after {MAX_RETRIES} attempts: {e}\")\n",
        "                        batch_texts.clear()\n",
        "                        batch_meta.clear()\n",
        "                        return\n",
        "                    print(f\"Embedding attempt {attempt} failed: {e}. Retrying in {backoff}s...\")\n",
        "                    time.sleep(backoff)\n",
        "                    backoff *= BACKOFF_FACTOR\n",
        "\n",
        "        for page_num, page in enumerate(pdf.pages, start=1):\n",
        "            # --- Text and Table Extraction ---\n",
        "            filtered = page\n",
        "            for table in page.find_tables():\n",
        "                table_chars = page.crop(table.bbox).chars\n",
        "                if not table_chars:\n",
        "                    continue\n",
        "                first_char = table_chars[0]\n",
        "                filtered = filtered.filter(\n",
        "                    lambda obj: get_bbox_overlap(obj_to_bbox(obj), table.bbox) is None\n",
        "                )\n",
        "                df = pd.DataFrame(table.extract())\n",
        "                df.columns = df.iloc[0]\n",
        "                md = df.drop(0).to_markdown(index=False)\n",
        "                filtered.chars.append(first_char | {\"text\": md})\n",
        "            text = extract_text(filtered.chars, layout=True).strip()\n",
        "\n",
        "            # --- Image Handling ---\n",
        "            image_docs = []\n",
        "            fitz_page = fitz_doc.load_page(page_num - 1)\n",
        "            for idx, img_info in enumerate(fitz_page.get_images(full=True), start=1):\n",
        "                xref = img_info[0]\n",
        "                img_data = fitz_doc.extract_image(xref)\n",
        "                img = Image.open(io.BytesIO(img_data[\"image\"]))\n",
        "                if img.mode in [\"1\", \"L\", \"P\"]:\n",
        "                    img = ImageOps.invert(img.convert(\"RGB\"))\n",
        "                fname = f\"{os.path.splitext(os.path.basename(pdf_path))[0]}_p{page_num}_i{idx}.{img_data['ext']}\"\n",
        "                fpath = os.path.join(image_folder, namespace, fname)\n",
        "                os.makedirs(os.path.dirname(fpath), exist_ok=True)\n",
        "                img.save(fpath)\n",
        "\n",
        "                img_id = str(uuid4())\n",
        "                image_docs.append({\n",
        "                    \"_id\": img_id,\n",
        "                    \"pdf\": os.path.basename(pdf_path),\n",
        "                    \"page\": page_num,\n",
        "                    \"filename\": fname,\n",
        "                    \"data\": img_data[\"image\"]\n",
        "                })\n",
        "\n",
        "            if image_docs:\n",
        "                mongo_coll.insert_many(image_docs)\n",
        "            image_ids = [doc[\"_id\"] for doc in image_docs]\n",
        "\n",
        "            # --- Batch Processing ---\n",
        "            if text:\n",
        "                batch_texts.append(text)\n",
        "                batch_meta.append({\n",
        "                    \"chunk_id\": make_chunk_id(make, model, pdf_name, page_num, 1, text),\n",
        "                    \"text\": text,\n",
        "                    \"pdf\": pdf_name,\n",
        "                    \"page\": page_num,\n",
        "                    \"chunk_index\": 1,\n",
        "                    \"image_ids\": image_ids,\n",
        "                    \"make\": make,\n",
        "                    \"model\": model,\n",
        "                    \"namespace\": namespace,\n",
        "                    \"schema_version\": CHUNK_SCHEMA_VERSION,\n",
        "                    \"ingestion_run_id\": ingestion_run_id,\n",
        "                    \"is_active\": True,\n",
        "                })\n",
        "                if len(batch_texts) >= EMBED_BATCH_SIZE:\n",
        "                    flush_batch()\n",
        "\n",
        "        # Final flush after processing all pages\n",
        "        flush_batch()\n",
        "        chunks_col.update_many(\n",
        "            {\n",
        "                \"make\": make,\n",
        "                \"model\": model,\n",
        "                \"namespace\": namespace,\n",
        "                \"pdf\": pdf_name,\n",
        "                \"ingestion_run_id\": {\"$ne\": ingestion_run_id},\n",
        "            },\n",
        "            {\"$set\": {\"is_active\": False, \"updated_at\": datetime.now(timezone.utc)}},\n",
        "        )"
      ],
      "metadata": {
        "id": "3uHpJFwY8meK"
      },
