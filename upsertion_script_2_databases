    {
      "cell_type": "markdown",
      "source": [
        "# 4. Main Execution\n",
        "\n",
        "Pinecone stores dense vectors for semantic retrieval. MongoDB `FixMate.manual_chunks` stores the same text chunks for BM25 lexical retrieval. The `chunk_id` value is stable and shared across Pinecone and MongoDB so RRF can deduplicate and merge dense and BM25 ranked results correctly."
      ],
      "metadata": {
        "id": "IeqOo2E-8nSh"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "%%time\n",
        "INDEX_NAME = \"nissan\"\n",
        "MAKE = INDEX_NAME\n",
        "index = ensure_pinecone_index(INDEX_NAME)\n",
        "\n",
        "for folder in os.listdir(CONTENT_DIR):\n",
        "    folder_path = os.path.join(CONTENT_DIR, folder)\n",
        "    if not os.path.isdir(folder_path):\n",
        "        continue\n",
        "\n",
        "    coll = mongo_db[folder]\n",
        "\n",
        "    for fname in os.listdir(folder_path):\n",
        "        if not fname.lower().endswith(\".pdf\"):\n",
